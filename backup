/* ══ VOICE ENGINE ══ */
var GT_LANG={en:'en',hi:'hi'};
var _audio=null,_speakQueue=[],_speaking=false;

function _normalizeTTS(text,lang){
  var TOKEN={
    en:{'MRP':'Maximum Retail Price','Tab':'Tablet','tab':'tablet','Cap':'Capsule','cap':'capsule','Inj':'Injection','Syp':'Syrup','Susp':'Suspension','WhatsApp':'Whatsapp','Rs':'Rupees','IP':'','BP':'','USP':'','NF':''},
    hi:{'MRP':'अधिकतम खुदरा मूल्य','Tab':'टैबलेट','Cap':'कैप्सूल','Inj':'इंजेक्शन','Syp':'सिरप','WhatsApp':'व्हाट्सएप','IP':'','BP':'','USP':''},
    od:{'MRP':'ସର୍ବାଧିକ ଖୁଚୁରା ମୂଲ୍ୟ','Tab':'ଟାବଲେଟ','Cap':'କ୍ୟାପସୁଲ','Inj':'ଇଞ୍ଜେକ୍ସନ','Syp':'ସିରପ','WhatsApp':'ହ୍ୱାଟ୍ସଆପ','IP':'','BP':'','USP':''}
  };
  var map=TOKEN[lang]||TOKEN.en;
  // strip emojis
  text=text.replace(/[\u{1F000}-\u{1FFFF}]/gu,' ').replace(/[©✕⟳▪*_#]/g,' ');
  // currency
  var r=lang==='hi'?'रुपये ':lang==='od'?'ଟଙ୍କା ':'Rupees ';
  text=text.replace(/₹/g,r);
  // dose patterns
  var mg=lang==='hi'?'मिलीग्राम':lang==='od'?'ମିଲିଗ୍ରାମ':'milligrams';
  var ml=lang==='hi'?'मिलीलीटर':lang==='od'?'ମିଲିଲିଟର':'millilitres';
  text=text.replace(/(\d+)\s*mg\b/gi,'$1 '+mg+' ').replace(/(\d+)\s*ml\b/gi,'$1 '+ml+' ');
  // token map — split on spaces, replace whole tokens only
  var out=text.split(/\s+/).map(function(tok){
    if(!tok)return '';
    // ALL-CAPS 2+ pure letters → Title Case so TTS reads as word
    if(/^[A-Z]{2,}$/.test(tok))tok=tok[0]+tok.slice(1).toLowerCase();
    return Object.prototype.hasOwnProperty.call(map,tok)?(map[tok]||''):tok;
  });
  return out.filter(Boolean).join(' ').replace(/\s+/g,' ').trim();
}

function speak(text,priority){
  var clean=_normalizeTTS(text,curLang);
  if(!clean)return;
  if(priority){_speakQueue=[];_speaking=false;if(_audio){_audio.pause();_audio.src='';_audio=null;}if(window.speechSynthesis)window.speechSynthesis.cancel();}
  _speakQueue.push(clean);
  if(!_speaking)_processQueue();
}
function _processQueue(){
  if(!_speakQueue.length){_speaking=false;return;}
  _speaking=true;
  var text=_speakQueue.shift();
  if(curLang==='od'){_speakWS(text,_processQueue);return;}
  _speakGT(text,function(ok){if(!ok)_speakWS(text,_processQueue);else _processQueue();});
}
function _speakGT(text,cb){
  try{
    var chunks=[];var words=text.split(' ');var cur='';
    for(var i=0;i<words.length;i++){var w=words[i];if((cur+' '+w).trim().length>180&&cur){chunks.push(cur.trim());cur=w;}else{cur=(cur+' '+w).trim();}}
    if(cur)chunks.push(cur);
    _playChunks(chunks,0,cb);
  }catch(e){cb(false);}
}
function _playChunks(chunks,idx,cb){
  if(idx>=chunks.length){cb(true);return;}
  var url='https://translate.googleapis.com/translate_tts?ie=UTF-8&tl='+(GT_LANG[curLang]||'en')+'&q='+encodeURIComponent(chunks[idx])+'&client=tw-ob&ttsspeed=0.9';
  var a=new Audio();_audio=a;a.volume=1;
  a.onended=function(){_playChunks(chunks,idx+1,cb);};
  a.onerror=function(){cb(false);};
  a.src=url;var p=a.play();if(p&&p.catch)p.catch(function(){cb(false);});
}
function _speakWS(text,cb){
  if(!window.speechSynthesis){if(cb)cb();return;}
  window.speechSynthesis.cancel();
  var u=new SpeechSynthesisUtterance(text);
  u.lang=L[curLang].voiceLang;u.rate=0.92;u.pitch=1;u.volume=1;
  var vs=window.speechSynthesis.getVoices(),px=u.lang.split('-')[0];
  var pref=vs.find(function(v){return v.lang===u.lang;})||vs.find(function(v){return v.lang.toLowerCase().startsWith('or');})||vs.find(function(v){return v.lang.startsWith(px)&&v.name.indexOf('Google')>-1;})||vs.find(function(v){return v.lang.startsWith(px);})||vs.find(function(v){return v.lang.startsWith('en');});
  if(pref)u.voice=pref;
  u.onend=function(){if(cb)cb();};u.onerror=function(){if(cb)cb();};
  window.speechSynthesis.speak(u);
}
if(window.speechSynthesis){window.speechSynthesis.getVoices();window.speechSynthesis.onvoiceschanged=function(){window.speechSynthesis.getVoices();};}


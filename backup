/* ══ CSV ══ */
function parseCSV(text){var rows=[],row=[],col='',q=false,i,ch;for(i=0;i<text.length;i++){ch=text[i];if(ch==='"'){q=!q;}else if(ch===','&&!q){row.push(col);col='';}else if((ch==='\n'||ch==='\r')&&!q){if(col||row.length){row.push(col);rows.push(row);row=[];col='';}}else{col+=ch;}}if(col)row.push(col);if(row.length)rows.push(row);return rows;}

/* ══ STATE ══ */
var products=[],filtered=[],cart={},visible=12;
var COL={name:0,pack:1,mrp:3,rate:4,company:5,composition:6};
var CSV_URL='https://docs.google.com/spreadsheets/d/e/2PACX-1vSkoAFrWFkerY629v3zhsV5q3NggnlHgSgBqZ2CnAK3n0riqW24dZN3iWm_JJz-XPf9Dtgkayaey-Vg/pub?output=csv';

fetch(CSV_URL).then(function(r){return r.text();}).then(function(txt){
  var rows=parseCSV(txt);if(!rows.length)return;
  var hdr=rows[0].map(function(h){return h.toLowerCase().trim();});
  function fC(kw,fb){for(var k=0;k<kw.length;k++)for(var i=0;i<hdr.length;i++)if(hdr[i].indexOf(kw[k])>-1)return i;return fb;}
  COL.name=fC(['product','name','medicine'],0);COL.pack=fC(['pack','qty','size'],1);
  COL.mrp=fC(['mrp','retail'],3);COL.rate=fC(['rate','price','ptr'],4);
  COL.company=fC(['company','manufacturer','brand'],5);COL.composition=fC(['composition','salt'],6);
  products=rows.slice(1).map(function(r,i){return{id:i,name:(r[COL.name]||'').trim(),pack:(r[COL.pack]||'').trim(),mrp:parseFloat((r[COL.mrp]||'').replace(/[^\d.]/g,''))||0,rate:parseFloat((r[COL.rate]||'').replace(/[^\d.]/g,''))||0,company:(r[COL.company]||'').trim(),composition:(r[COL.composition]||'').trim(),imageUrl:(r[8]||'').trim()};}).filter(function(p){return p.name;});
  filtered=products.slice();buildDropdowns();render(true);
  _queueWelcome(products.length);
}).catch(function(e){
  console.error(e);
  document.getElementById('list').innerHTML='<div class="empty-state"><div style="font-size:2.5rem">⚠️</div><div>'+s('noProducts')+'</div></div>';
  speak(s('vFail'),true);
});

function buildDropdowns(){
  var cS={},cos=[],xS={},cxs=[];
  products.forEach(function(p){if(p.company&&!cS[p.company]){cS[p.company]=1;cos.push(p.company);}if(p.composition&&!xS[p.composition]){xS[p.composition]=1;cxs.push(p.composition);}});
  cos.sort();cxs.sort();
  var fc=document.getElementById('filterCompany');fc.innerHTML='<option value="">'+s('allCo')+'</option>';cos.forEach(function(c){var o=document.createElement('option');o.value=c;o.textContent=c;fc.appendChild(o);});
  var fx=document.getElementById('filterComposition');fx.innerHTML='<option value="">'+s('allCx')+'</option>';cxs.forEach(function(x){var o=document.createElement('option');o.value=x;o.textContent=x;fx.appendChild(o);});
}

var _ft=null;
function doFilter(){
  var sv=(document.getElementById('search').value||'').toLowerCase().trim();
  var c=document.getElementById('filterCompany').value,cx=document.getElementById('filterComposition').value;
  filtered=products.filter(function(p){if(c&&p.company!==c)return false;if(cx&&p.composition!==cx)return false;if(sv){var h=(p.name+' '+p.company+' '+p.composition).toLowerCase();if(h.indexOf(sv)===-1)return false;}return true;});
  visible=12;render(true);
  clearTimeout(_ft);_ft=setTimeout(function(){if(filtered.length===0)speak(s('vNone'),true);else if(sv||c||cx)speak(L[curLang].vFound(filtered.length));},700);
}

function toImgUrl(url){if(!url)return'';url=url.trim();if(url.indexOf('lh3.googleusercontent.com')>-1)return url.replace(/=[wsh]\d+[^"]*$/,'')+'=w400';var m1=url.match(/drive\.google\.com\/file\/d\/([a-zA-Z0-9_-]+)/);if(m1)return'https://drive.google.com/thumbnail?id='+m1[1]+'&sz=w400';var m2=url.match(/[?&]id=([a-zA-Z0-9_-]+)/);if(m2)return'https://drive.google.com/thumbnail?id='+m2[1]+'&sz=w400';return'';}
function esc(v){return String(v||'').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;');}

function render(reset){
  var list=document.getElementById('list');
  if(reset){list.innerHTML='';if(!filtered.length){list.innerHTML='<div class="empty-state"><div style="font-size:2.5rem">🔍</div><div>'+s('noProducts')+'</div></div>';return;}}
  filtered.slice(0,visible).forEach(function(p){
    if(document.getElementById('card-'+p.id))return;
    var d=document.createElement('div');d.className='item';d.id='card-'+p.id;
    var iw=document.createElement('div');iw.className='item-img-wrap';
    var cv=toImgUrl(p.imageUrl||'');
    if(cv){var img=document.createElement('img');img.src=cv;img.alt=p.name;(function(src,name,wrap){img.onerror=function(){wrap.innerHTML='<div class="item-img-blank"><span>📷</span></div>';wrap.style.cursor='default';};wrap.addEventListener('click',function(){if(img.complete&&img.naturalWidth)openLightbox(src,name);});})(cv,p.name,iw);iw.appendChild(img);iw.insertAdjacentHTML('beforeend','<span class="img-tap-hint">🔍</span>');}
    else{iw.innerHTML='<div class="item-img-blank"><span>📷</span></div>';iw.style.cursor='default';}
    d.appendChild(iw);
    var ch=p.composition?'<div class="item-composition">🧪 '+esc(p.composition)+'</div>':'';
    var rest=document.createElement('div');rest.style.cssText='display:contents';
    rest.innerHTML='<div class="item-content"><div class="item-name">'+esc(p.name)+'</div><div class="item-company">'+esc(p.company)+'</div><span class="item-pack">📦 '+esc(p.pack)+'</span>'+ch+'<div class="price-row"><span class="rate-price">&#8377;'+p.rate.toFixed(2)+'</span><span class="mrp-price">MRP &#8377;'+p.mrp.toFixed(2)+'</span></div><div class="spacer"></div><div class="controls" id="ctrl-'+p.id+'">'+mkCtrl(p.id,cart[p.id]||0)+'</div></div>';
    d.appendChild(rest);list.appendChild(d);
  });
}
function mkCtrl(id,qty){if(!qty)return'<button class="btn-add" onclick="upd('+id+',1)">'+s('addCart')+'</button>';return'<div class="qty-control"><button class="btn-qty" onclick="upd('+id+',-1)">−</button><span class="qty-num">'+qty+'</span><button class="btn-qty" onclick="upd('+id+',1)">+</button></div>';}
function upd(id,d){var prev=cart[id]||0;cart[id]=prev+d;if(cart[id]<0)cart[id]=0;var c=document.getElementById('ctrl-'+id);if(c)c.innerHTML=mkCtrl(id,cart[id]);refreshCart();var name=products[parseInt(id,10)]?products[parseInt(id,10)].name:'item';if(prev===0&&cart[id]===1)speak(L[curLang].vAdded(name));else if(cart[id]===0)speak(L[curLang].vRemoved(name));else speak(L[curLang].vQty(cart[id]));}
function _calcCart(){
  var total=0,count=0;
  for(var id in cart){
    var qty=cart[id]||0;
    if(qty>0&&products[parseInt(id,10)]){
      var rate=products[parseInt(id,10)].rate||0;
      total=Math.round((total+qty*rate)*100)/100;
      count+=qty;
    }
  }
  return{total:total,count:count};
}
function refreshCart(){
  var c=_calcCart();
  document.getElementById('cartCount').textContent=c.count===0?s('cartZero'):L[curLang].cartN(c.count);
  document.getElementById('cartTotal').textContent='₹'+c.total.toFixed(2);
}
new IntersectionObserver(function(e){if(e[0].isIntersecting){visible+=12;render(false);}},{rootMargin:'250px'}).observe(document.getElementById('sentinel'));

/* ══ WHATSAPP ══ */
function sendOrder(){
  var shop=(document.getElementById('shop').value||'').trim(),mob=(document.getElementById('mobile').value||'').trim();
  if(!shop&&!mob){showModal('⚠️',s('errBoth'),function(){highlight('shop');highlight('mobile');document.getElementById('shop').focus();});return;}
  if(!shop){showModal('🏪',s('errShop'),function(){highlight('shop');document.getElementById('shop').focus();});return;}
  if(!mob){showModal('📱',s('errMobile'),function(){highlight('mobile');document.getElementById('mobile').focus();});return;}
  var has=false;for(var x in cart){if(cart[x]>0){has=true;break;}}
  if(!has){showModal('🛒',s('errCart'));return;}
  var msg='🧾 *New Order*%0A*Shop:* '+encodeURIComponent(shop)+'%0A*Mobile:* '+encodeURIComponent(mob)+'%0A%0A';
  var total=0,count=0;
  for(var id in cart){if(cart[id]>0){var p=products[parseInt(id,10)],amt=Math.round(cart[id]*p.rate*100)/100;total=Math.round((total+amt)*100)/100;count+=cart[id];msg+='▪ '+encodeURIComponent(p.name)+' × '+cart[id]+' = ₹'+amt.toFixed(2)+'%0A';}}
  msg+='%0A*Total: ₹'+total.toFixed(2)+'*';
  speak(L[curLang].vOrder(count,total,shop),true);
  closeBill();
  window.open('https://wa.me/919533762508?text='+msg);
}

/* ══ BILL ══ */
function _cartItems(){
  var items=[];
  for(var id in cart){
    var qty=cart[id]||0;
    var idx=parseInt(id,10);
    if(qty>0&&products[idx]){
      var rate=products[idx].rate||0;
      var amt=Math.round(qty*rate*100)/100;
      items.push({
        name:products[idx].name,
        company:products[idx].company,
        pack:products[idx].pack,
        rate:rate,
        qty:qty,
        amount:amt
      });
    }
  }
  items.sort(function(a,b){return a.name.localeCompare(b.name);});
  return items;
}

function openBill(){
  var shop=(document.getElementById('shop').value||'').trim(),mob=(document.getElementById('mobile').value||'').trim();
  if(!shop&&!mob){showModal('⚠️',s('errBoth'),function(){highlight('shop');highlight('mobile');document.getElementById('shop').focus();});return;}
  if(!shop){showModal('🏪',s('errShop'),function(){highlight('shop');document.getElementById('shop').focus();});return;}
  if(!mob){showModal('📱',s('errMobile'),function(){highlight('mobile');document.getElementById('mobile').focus();});return;}
  var items=_cartItems();
  if(!items.length){showModal('🛒',s('errCart'));return;}

  var grandTotal=Math.round(items.reduce(function(acc,i){return acc+i.amount;},0)*100)/100;
  var coMap={};items.forEach(function(it){if(!coMap[it.company])coMap[it.company]={qty:0,amount:0};coMap[it.company].qty+=it.qty;coMap[it.company].amount=Math.round((coMap[it.company].amount+it.amount)*100)/100;});

  var now=new Date();
  var ds=now.toLocaleDateString('en-IN',{day:'2-digit',month:'short',year:'numeric'});
  var ts=now.toLocaleTimeString('en-IN',{hour:'2-digit',minute:'2-digit'});
  document.getElementById('boDate').textContent=ds+' '+ts;

  var iRows=items.map(function(it){return'<tr><td><div class="bill-pname">'+esc(it.name)+'</div><div class="bill-co">'+esc(it.company)+'</div>'+(it.pack?'<div class="bill-pack">'+esc(it.pack)+'</div>':'')+' </td><td class="c">'+it.qty+'</td><td class="r">&#8377;'+it.rate.toFixed(2)+'</td><td class="r"><strong>&#8377;'+it.amount.toFixed(2)+'</strong></td></tr>';}).join('');

  var cRows=Object.keys(coMap).sort().map(function(co){var d=coMap[co];return'<tr><td><strong>'+esc(co)+'</strong></td><td class="c">'+d.qty+'</td><td class="r"><strong>&#8377;'+d.amount.toFixed(2)+'</strong></td></tr>';}).join('');

  document.getElementById('boBody').innerHTML=
    '<div class="bill-card">'+
      '<div class="bill-shop">'+
        '<div class="bill-shop-name">💊 Aaradhya Pharmaceuticals</div>'+
        '<div class="bill-shop-meta">'+
          '<span><strong>'+esc(shop)+'</strong>Shop</span>'+
          '<span><strong>'+esc(mob)+'</strong>Mobile</span>'+
          '<span><strong>'+ds+'</strong>Date</span>'+
          '<span><strong>'+ts+'</strong>Time</span>'+
        '</div>'+
      '</div>'+
      '<div class="bill-sec-hdr">📋 Ordered Items</div>'+
      '<table class="bill-tbl"><thead><tr><th>Product</th><th class="c">Qty</th><th class="r">Rate</th><th class="r">Amount</th></tr></thead>'+
      '<tbody>'+iRows+'</tbody>'+
      '<tfoot><tr class="bill-tfoot"><td colspan="3">GRAND TOTAL</td><td class="r">&#8377;'+grandTotal.toFixed(2)+'</td></tr></tfoot></table>'+
      '<div class="bill-divider"></div>'+
      '<div class="bill-sec-hdr">🏭 Company-wise Summary</div>'+
      '<table class="bill-tbl"><thead><tr><th>Company</th><th class="c">Units</th><th class="r">Total</th></tr></thead>'+
      '<tbody>'+cRows+'</tbody>'+
      '<tfoot><tr class="bill-tfoot"><td colspan="2">TOTAL</td><td class="r">&#8377;'+grandTotal.toFixed(2)+'</td></tr></tfoot></table>'+
      '<div class="bill-footer"><em style="color:#e53935;font-weight:600;font-size:0.75rem;">* All prices are exclusive of taxes.</em><br><br><strong>Aaradhya Pharmaceuticals</strong> &bull; Aaratech &bull; Powered by AI</div>'+
    '</div>';

  document.getElementById('billOverlay').classList.add('show');
  document.body.style.overflow='hidden';
  speak(s('vBillReady'),true);
}

function closeBill(){document.getElementById('billOverlay').classList.remove('show');document.body.style.overflow='';}

function downloadBill(fmt){
  // Disable buttons while generating
  var foot=document.querySelector('#billOverlay .bo-foot');
  var orig=foot.innerHTML;
  foot.innerHTML='<div style="display:flex;align-items:center;justify-content:center;gap:10px;width:100%;color:#666;font-size:.9rem"><div class="spinner" style="width:22px;height:22px;border-width:2px;border-color:#dae3ef;border-top-color:#1a6bbd"></div>Generating '+fmt.toUpperCase()+'…</div>';

  function restore(){foot.innerHTML=orig;}

  function loadScript(url,cb){
    var s=document.createElement('script');s.src=url;
    s.onload=cb;s.onerror=function(){restore();showModal('⚠️','Could not load library. Check internet.');};
    document.head.appendChild(s);
  }

  var target=document.getElementById('boBody');
  var shop=(document.getElementById('shop').value||'order').trim().replace(/\s+/g,'_');
  var fname='Aaradhya_Bill_'+shop+'_'+new Date().toISOString().slice(0,10);

  function doCapture(){
    // Scroll target to top
    target.scrollTop=0;
    // Temporarily expand to full height for capture
    var prevH=target.style.height,prevO=target.style.overflow;
    target.style.height=target.scrollHeight+'px';
    target.style.overflow='visible';

    html2canvas(target,{scale:2,useCORS:true,backgroundColor:'#f0f4f9',logging:false}).then(function(canvas){
      target.style.height=prevH;target.style.overflow=prevO;
      if(fmt==='jpg'){
        canvas.toBlob(function(blob){
          var a=document.createElement('a');a.href=URL.createObjectURL(blob);a.download=fname+'.jpg';a.click();
          restore();speak('Bill downloaded as JPG');
        },'image/jpeg',0.95);
      } else {
        if(!window.jspdf){
          loadScript('https://cdnjs.cloudflare.com/ajax/libs/jspdf/2.5.1/jspdf.umd.min.js',function(){doPDF(canvas,fname);restore();speak('Bill downloaded as PDF');});
        } else {doPDF(canvas,fname);restore();speak('Bill downloaded as PDF');}
      }
    }).catch(function(e){console.error(e);target.style.height=prevH;target.style.overflow=prevO;restore();showModal('⚠️','Could not generate bill. Try again.');});
  }

  function doPDF(canvas,fname){
    var jsPDF=window.jspdf.jsPDF;
    var iw=canvas.width,ih=canvas.height;
    var pw=210,ph=Math.round((ih/iw)*pw);
    var pdf=new jsPDF({orientation:ph>pw?'portrait':'landscape',unit:'mm',format:[pw,ph]});
    pdf.addImage(canvas.toDataURL('image/jpeg',0.95),'JPEG',0,0,pw,ph);
    pdf.save(fname+'.pdf');
  }

  if(!window.html2canvas){
    loadScript('https://cdnjs.cloudflare.com/ajax/libs/html2canvas/1.4.1/html2canvas.min.js',doCapture);
  } else {doCapture();}
}

